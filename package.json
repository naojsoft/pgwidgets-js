{
  "name": "pgwidgets",
  "version": "0.2.1",
  "description": "A native JavaScript widget library with Qt/GTK-style layout and controls",
  "type": "module",
  "main": "Widgets.js",
  "module": "Widgets.js",
  "exports": {
    ".": "./Widgets.js",
    "./Widgets.css": "./Widgets.css",
    "./css/*": "./pgwidgets_js/static/css/*",
    "./modules/*": "./pgwidgets_js/static/modules/*",
    "./icons/*": "./pgwidgets_js/static/icons/*"
  },
  "files": [
    "Widgets.js",
    "Widgets.css",
    "pgwidgets_js/static/"
  ],
  "keywords": [
    "widgets",
    "ui",
    "gui",
    "layout",
    "mdi",
    "dialog",
    "toolbar",
    "menu"
  ],
  "author": "PGWidgets Developers",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/naojsoft/pgwidgets-js.git"
  }
}
