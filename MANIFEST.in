include Widgets.js
include Widgets.css
include LICENSE.md
include README.md
include package.json
# All static assets live under pgwidgets_js/static/{modules,css,icons}.
# Wheel inclusion is handled by [tool.setuptools.package-data] in
# pyproject.toml; this rule is for the sdist (source tarball).
recursive-include pgwidgets_js *.py *.html *.js *.css *.svg
